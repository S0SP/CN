## Program 2: Telephone Billing System

```java
// CallBase.java - Base class
public class CallBase {
    
    private String callerName;
    private String callerNumber;
    
    // Default constructor
    public CallBase() {
        this.callerName   = "Unknown";
        this.callerNumber = "0000000000";
    }
    
    // Parameterized constructor
    public CallBase(String callerName, String callerNumber) {
        this.callerName   = callerName;
        this.callerNumber = callerNumber;
    }
    
    // Getters and Setters
    public String getCallerName()              { return callerName;   }
    public void   setCallerName(String name)   { this.callerName = name; }
    
    public String getCallerNumber()            { return callerNumber; }
    public void   setCallerNumber(String num)  { this.callerNumber = num; }
    
    public void displayInfo() {
        System.out.println("Caller Name   : " + callerName);
        System.out.println("Caller Number : " + callerNumber);
    }
}
```

```java
// LocalCall.java
// Rate: 1 unit per 3 minutes (fraction counted as full 3 min)
// Assume 1 unit = Rs. 1.00
public class LocalCall extends CallBase {
    
    private int    durationMinutes; // call duration in minutes
    private double ratePerUnit;     // cost per unit
    
    // Default constructor
    public LocalCall() {
        super();
        this.durationMinutes = 0;
        this.ratePerUnit     = 1.00;
    }
    
    // Parameterized constructor
    public LocalCall(String callerName, String callerNumber,
                     int durationMinutes, double ratePerUnit) {
        super(callerName, callerNumber);
        // Input validation
        this.durationMinutes = (durationMinutes > 0) ? durationMinutes : 0;
        this.ratePerUnit     = (ratePerUnit > 0)     ? ratePerUnit     : 1.00;
    }
    
    // Getters and Setters
    public int    getDurationMinutes()            { return durationMinutes; }
    public void   setDurationMinutes(int d)       { 
        this.durationMinutes = (d > 0) ? d : 0; 
    }
    
    public double getRatePerUnit()                { return ratePerUnit; }
    public void   setRatePerUnit(double r)        { 
        this.ratePerUnit = (r > 0) ? r : 1.00; 
    }
    
    // Calculate number of units (ceiling division: fraction = 1 full unit)
    public int calculateUnits() {
        return (int) Math.ceil(durationMinutes / 3.0);
    }
    
    // Calculate bill amount
    public double calculateBill() {
        return calculateUnits() * ratePerUnit;
    }
    
    // Display local call bill
    public void displayBill() {
        System.out.println("========== LOCAL CALL BILL ==========");
        displayInfo();
        System.out.println("Duration      : " + durationMinutes + " minutes");
        System.out.println("Units Charged : " + calculateUnits() + " units");
        System.out.println("Rate/Unit     : Rs. " + ratePerUnit);
        System.out.printf ("Total Bill    : Rs. %.2f%n", calculateBill());
        System.out.println("=====================================");
    }
}
```

```java
// LongCall.java (STD Call)
/*
 * Rate Table (assumed from attachment):
 * Time Slot       | Rate per unit
 * 08:00 - 18:00   | Rs. 2.00 / min
 * 18:00 - 22:00   | Rs. 1.50 / min
 * 22:00 - 08:00   | Rs. 1.00 / min  (night rate)
 *
 * If same area code (STD code) => local rate applied
 */
public class LongCall extends CallBase {
    
    private int    durationMinutes;
    private int    callHour;         // 0-23 format
    private String originCode;       // STD code of origin
    private String destCode;         // STD code of destination
    
    // Default constructor
    public LongCall() {
        super();
        this.durationMinutes = 0;
        this.callHour        = 10;
        this.originCode      = "000";
        this.destCode        = "000";
    }
    
    // Parameterized constructor
    public LongCall(String callerName, String callerNumber,
                    int durationMinutes, int callHour,
                    String originCode, String destCode) {
        super(callerName, callerNumber);
        this.durationMinutes = (durationMinutes > 0)              ? durationMinutes : 0;
        this.callHour        = (callHour >= 0 && callHour <= 23)  ? callHour        : 10;
        this.originCode      = originCode;
        this.destCode        = destCode;
    }
    
    // Getters and Setters
    public int    getDurationMinutes()           { return durationMinutes; }
    public void   setDurationMinutes(int d)      { 
        this.durationMinutes = (d > 0) ? d : 0; 
    }
    
    public int    getCallHour()                  { return callHour; }
    public void   setCallHour(int h)             { 
        this.callHour = (h >= 0 && h <= 23) ? h : 10; 
    }
    
    public String getOriginCode()                { return originCode; }
    public void   setOriginCode(String code)     { this.originCode = code; }
    
    public String getDestCode()                  { return destCode; }
    public void   setDestCode(String code)       { this.destCode = code; }
    
    // Determine rate per minute based on time slot
    public double getRatePerMinute() {
        // Same area code => local STD rate (discounted)
        if (originCode.equals(destCode)) {
            return 0.50; // same zone discount
        }
        // Peak hours 08:00 - 17:59
        if (callHour >= 8 && callHour < 18) {
            return 2.00;
        }
        // Evening 18:00 - 21:59
        else if (callHour >= 18 && callHour < 22) {
            return 1.50;
        }
        // Night 22:00 - 07:59
        else {
            return 1.00;
        }
    }
    
    // Determine time slot description
    private String getTimeSlotDesc() {
        if (callHour >= 8 && callHour < 18)  return "Peak    (08:00-18:00)";
        if (callHour >= 18 && callHour < 22) return "Evening (18:00-22:00)";
        return "Night   (22:00-08:00)";
    }
    
    // Calculate total bill
    public double calculateBill() {
        return durationMinutes * getRatePerMinute();
    }
    
    // Display STD call bill
    public void displayBill() {
        System.out.println("========== STD CALL BILL ============");
        displayInfo();
        System.out.println("Origin STD Code : " + originCode);
        System.out.println("Dest   STD Code : " + destCode);
        System.out.println("Call Hour       : " + callHour + ":00");
        System.out.println("Time Slot       : " + getTimeSlotDesc());
        System.out.println("Duration        : " + durationMinutes + " minutes");
        System.out.printf ("Rate/Minute     : Rs. %.2f%n", getRatePerMinute());
        System.out.printf ("Total Bill      : Rs. %.2f%n", calculateBill());
        System.out.println("=====================================");
    }
}
```

